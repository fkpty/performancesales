# Backend Environment Variables
# Copy this to .env and fill in your values

NODE_ENV=development
PORT=3003

# MySQL (XAMPP)
DB_HOST=10.0.0.187
DB_PORT=3306
DB_USER=performance_sales_app
DB_PASSWORD=replace_with_db_password
DB_NAME=performance_sales_db

# PBS Hub database (same MySQL instance – for session validation)
HUB_DB_NAME=pbs_hub
HUB_DB_USER=performance_sales_app
HUB_DB_PASSWORD=replace_with_db_password

# CORS – origins allowed to call the API
CORS_ORIGINS=https://hub.collab.grouppbs.com,https://10.0.0.187,https://10.0.0.187:5173,http://10.0.0.187:5173
ALLOW_LOCAL_DEV_AUTH=1

BIND_HOST=0.0.0.0

# Session cookie name set by the PHP auth bridge
AUTH_COOKIE=performance_sales_token
PROXY_SHARED_SECRET=replace_with_shared_proxy_secret
PERFORMANCE_SALES_EMBED_SECRET=replace_with_embed_secret

# SQL Server source for contratos vigentes
SQLSERVER_HOST=11.11.0.10
SQLSERVER_PORT=1433
SQLSERVER_DB_NAME=XLAR
SQLSERVER_USER=
SQLSERVER_PASSWORD=
SQLSERVER_ENCRYPT=false
SQLSERVER_TRUST_CERT=true
